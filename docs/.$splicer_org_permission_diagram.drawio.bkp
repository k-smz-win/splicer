                    <mxGeometry x="520" y="468" width="220" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="lnote" value="ロール使用場面の目安（設計上は会社種別に依存させない）：&lt;br/&gt;管理会社 / 販売会社 / 代理店　→　シスアド、ユーザー　　　顧客　→　シスアド、マネージャー、作業者" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#AED6F1;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" parent="1" vertex="1">
