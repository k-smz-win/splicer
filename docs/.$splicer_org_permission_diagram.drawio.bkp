                <mxCell id="r1l" value="&lt;b&gt;シスアド&lt;/b&gt;" style="whiteSpace=wrap;html=1;fillColor=#2C3E50;strokeColor=#2C3E50;fontColor=#FFFFFF;fontSize=13;align=center;" parent="1" vertex="1">
