                <mxCell id="h7" value="&lt;b&gt;project:assign&lt;/b&gt;&lt;br/&gt;PJアサイン" style="whiteSpace=wrap;html=1;fillColor=#2C3E50;strokeColor=#2C3E50;fontColor=#FFFFFF;fontSize=11;align=center;" parent="1" vertex="1">
