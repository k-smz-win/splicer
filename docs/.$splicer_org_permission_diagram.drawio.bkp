                <mxCell id="r1c1" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=24;align=center;fontColor=#27AE60;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="225" y="195" width="197" height="62" as="geometry"/>
