<mxfile host="65bd71144e" pages="5">
    <diagram name="①RBACとは" id="page1">
        <mxGraphModel dx="565" dy="861" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="t1" value="① RBACとは何か" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=26;fontStyle=1;fontColor=#2C3E50;" parent="1" vertex="1">
                    <mxGeometry x="50" y="20" width="1554" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="prob" value="&lt;b&gt;現状の問題（なぜ変えるのか）&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;現在の設計は「会社種別ごとに権限が決まっている」アンチパターンです。&lt;br/&gt;・会社種別（管理会社・顧客など）に権限が紐づいており、責務が曖昧&lt;br/&gt;・新しい役割を追加するたびにコードを修正しなければならない&lt;br/&gt;・誰が何の権限を持っているか一目で分からない&lt;br/&gt;&lt;br/&gt;→ これを解消するために RBAC（ロールベースアクセス制御）に整理します。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEDEC;strokeColor=#E74C3C;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="50" y="68" width="1554" height="152" as="geometry"/>
                </mxCell>
                <mxCell id="def" value="&lt;b&gt;RBACとは（Role-Based Access Control）&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;「ユーザーに直接権限を与えるのではなく、ロール（役割）を通じて権限を管理する」考え方です。&lt;br/&gt;&lt;br/&gt;例）山田さんは「シスアド」ロールを持つ　→　シスアドは「project:create」権限を持つ　→　山田さんは project:create ができる&lt;br/&gt;&lt;br/&gt;User の権限を変えたいときは「ロールを付け替えるだけ」。個別に Permission を設定する必要はありません。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;arcSize=7;" parent="1" vertex="1">
                    <mxGeometry x="50" y="234" width="1554" height="144" as="geometry"/>
                </mxCell>
                <mxCell id="ba" value="&lt;b&gt;Role と Permission の関係&lt;/b&gt;&lt;br/&gt;&lt;hr/&gt;Role　＝　権限のセット（まとめ）&lt;br/&gt;Permission　＝　具体的な操作1つ&lt;br/&gt;&lt;br/&gt;例）Role「マネージャー」が含む Permission：&lt;br/&gt;　・project:create&lt;br/&gt;　・project:update&lt;br/&gt;　・project:assign&lt;br/&gt;&lt;br/&gt;Role に Permission をまとめておき&lt;br/&gt;User に Role を割り当てる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="50" y="390" width="511" height="255" as="geometry"/>
                </mxCell>
                <mxCell id="bb" value="&lt;b&gt;なぜ User に直接権限を持たせないのか&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;b&gt;悪い例&lt;/b&gt;：User → Permission（直接付与）&lt;br&gt;　・社員100人なら100回個別設定&lt;br&gt;　・退職時に権限削除漏れが起きやすい&lt;br&gt;　・誰が何の権限を持つか把握困難&lt;br&gt;&lt;br&gt;&lt;b&gt;良い例&lt;/b&gt;：User → Role → Permission&lt;br&gt;　・ロールを付け替えるだけで権限変更&lt;br&gt;　・管理が一か所に集中（シンプル）&lt;br&gt;　・「このロールは何ができるか」が明確&lt;br&gt;　・監査しやすい" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFAF1;strokeColor=#27AE60;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;arcSize=5;" parent="1" vertex="1">
                    <mxGeometry x="582" y="390" width="510" height="255" as="geometry"/>
                </mxCell>
                <mxCell id="bc" value="&lt;b&gt;なぜ拡張しやすいのか&lt;/b&gt;&lt;br/&gt;&lt;hr/&gt;新機能の追加（例：レポート出力）：&lt;br/&gt;　1. Permission「report:export」を追加&lt;br/&gt;　2. 必要な Role に紐づける&lt;br/&gt;　3. 完了（User への変更は不要）&lt;br/&gt;&lt;br/&gt;新メンバーの追加：&lt;br/&gt;　1. User を作成&lt;br/&gt;　2. Role を割り当てる&lt;br/&gt;　3. 完了（Permission 個別設定は不要）&lt;br/&gt;&lt;br/&gt;会社や組織が変わっても&lt;br/&gt;Role の設計は変える必要なし" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#F39C12;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;arcSize=5;" parent="1" vertex="1">
                    <mxGeometry x="1114" y="390" width="490" height="255" as="geometry"/>
                </mxCell>
                <mxCell id="fu" value="&lt;b&gt;User&lt;/b&gt;&lt;br/&gt;ユーザー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#27AE60;strokeColor=#1E8449;fontColor=#FFFFFF;fontSize=15;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="280" y="695" width="180" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="fr" value="&lt;b&gt;Role&lt;/b&gt;&lt;br/&gt;ロール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;strokeColor=#C0392B;fontColor=#FFFFFF;fontSize=15;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="737" y="695" width="180" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="fp" value="&lt;b&gt;Permission&lt;/b&gt;&lt;br/&gt;権限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C0392B;strokeColor=#922B21;fontColor=#FFFFFF;fontSize=15;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1194" y="695" width="180" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="fe1" value="ロールを持つ" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27AE60;strokeWidth=3;fontSize=12;fontStyle=1;fontColor=#1E8449;endArrow=block;endFill=1;" parent="1" source="fu" target="fr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fe2" value="権限を含む" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C0392B;strokeWidth=3;fontSize=12;fontStyle=1;fontColor=#C0392B;endArrow=block;endFill=1;" parent="1" source="fr" target="fp" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fl" value="この間接的な紐づけが RBAC の本質" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=2;fontColor=#7F8C8D;" parent="1" vertex="1">
                    <mxGeometry x="280" y="780" width="1094" height="26" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
