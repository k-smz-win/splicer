        <mxCell id="r1c6" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=22;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1000" y="195" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r1c7" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=22;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1155" y="195" width="155" height="60" as="geometry"/></mxCell>

        <!-- Row ユーザー -->
        <mxCell id="r2l" value="&lt;b&gt;ユーザー&lt;/b&gt;" style="whiteSpace=wrap;html=1;fillColor=#3498DB;strokeColor=#2980B9;fontColor=#FFFFFF;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="255" width="175" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c1" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="225" y="255" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c2" value="△&lt;br/&gt;&lt;font style=&apos;font-size:10px;&apos;&gt;自分のみ&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=18;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380" y="255" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c3" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="535" y="255" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c4" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="690" y="255" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c5" value="△&lt;br/&gt;&lt;font style=&apos;font-size:10px;&apos;&gt;参加PJのみ&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=18;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="845" y="255" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c6" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1000" y="255" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r2c7" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1155" y="255" width="155" height="60" as="geometry"/></mxCell>

        <!-- Row マネージャー -->
        <mxCell id="r3l" value="&lt;b&gt;マネージャー&lt;/b&gt;" style="whiteSpace=wrap;html=1;fillColor=#8E44AD;strokeColor=#6C3483;fontColor=#FFFFFF;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="315" width="175" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c1" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="225" y="315" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c2" value="△&lt;br/&gt;&lt;font style=&apos;font-size:10px;&apos;&gt;チーム内のみ&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=18;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380" y="315" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c3" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="535" y="315" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c4" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=22;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="690" y="315" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c5" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=22;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="845" y="315" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c6" value="△&lt;br/&gt;&lt;font style=&apos;font-size:10px;&apos;&gt;自分のPJのみ&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=18;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1000" y="315" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r3c7" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=22;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1155" y="315" width="155" height="60" as="geometry"/></mxCell>

        <!-- Row 作業者 -->
        <mxCell id="r4l" value="&lt;b&gt;作業者&lt;/b&gt;" style="whiteSpace=wrap;html=1;fillColor=#E67E22;strokeColor=#CA6F1E;fontColor=#FFFFFF;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="375" width="175" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c1" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="225" y="375" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c2" value="△&lt;br/&gt;&lt;font style=&apos;font-size:10px;&apos;&gt;自分のみ&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=18;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380" y="375" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c3" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="535" y="375" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c4" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="690" y="375" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c5" value="△&lt;br/&gt;&lt;font style=&apos;font-size:10px;&apos;&gt;参加PJのみ&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=18;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="845" y="375" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c6" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1000" y="375" width="155" height="60" as="geometry"/></mxCell>
        <mxCell id="r4c7" value="×" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=22;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1155" y="375" width="155" height="60" as="geometry"/></mxCell>

        <!-- Legend -->
        <mxCell id="lo" value="○　制限なし可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="460" width="200" height="32" as="geometry"/></mxCell>
        <mxCell id="ld" value="△　条件付き可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;fontColor=#D35400;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="265" y="460" width="200" height="32" as="geometry"/></mxCell>
        <mxCell id="lx" value="×　不可" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;align=center;fontColor=#C0392B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="480" y="460" width="200" height="32" as="geometry"/></mxCell>

        <mxCell id="lnote" value="ロール使用場面の目安（設計上は会社に依存させない）：&lt;br/&gt;管理会社 / 販売会社 / 代理店　→　シスアド、ユーザー&lt;br/&gt;顧客　→　シスアド、マネージャー、作業者"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#AED6F1;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;"
          vertex="1" parent="1"><mxGeometry x="50" y="510" width="500" height="80" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="④設計意図" id="page4">
    <mxGraphModel dx="1422" dy="762" grid="0" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="t4" value="④ 設計意図　―　なぜこの設計にしたのか"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=26;fontStyle=1;fontColor=#2C3E50;"
          vertex="1" parent="1"><mxGeometry x="50" y="20" width="1554" height="50" as="geometry"/></mxCell>

        <mxCell id="b1" value="&lt;b&gt;① なぜ RBAC にしたのか&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;以前の設計は「会社種別ごとに権限を判定」していました。コードの中で if (company.type === '管理会社') のような条件が増え続けるアンチパターンです。&lt;br/&gt;&lt;br/&gt;RBACにより：&lt;br/&gt;・権限の判定を「RoleのPermissionを確認する」1パターンに統一&lt;br/&gt;・会社種別の変更・追加があっても権限ロジックは変わらない&lt;br/&gt;・「この人は何ができるか」がロールを見るだけで分かる"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;"
          vertex="1" parent="1"><mxGeometry x="50" y="85" width="730" height="220" as="geometry"/></mxCell>

        <mxCell id="b2" value="&lt;b&gt;② なぜ会社と権限を分離したのか&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;組織構造（誰がどの会社に属するか）と権限管理（誰が何をできるか）は、別の関心事です。&lt;br/&gt;&lt;br/&gt;・A社の管理者もB社の管理者も「シスアド」ロールを使う&lt;br/&gt;・会社が増えても、権限の設計は変えなくてよい&lt;br/&gt;・「組織の変更」と「権限の変更」を独立して管理できる&lt;br/&gt;&lt;br/&gt;→ 責務が明確になり、保守しやすくなる"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEDEC;strokeColor=#E74C3C;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;"
          vertex="1" parent="1"><mxGeometry x="824" y="85" width="780" height="220" as="geometry"/></mxCell>

        <mxCell id="b3" value="&lt;b&gt;③ なぜロールを抽象化したのか&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Userに直接Permissionを付けると：&lt;br/&gt;・100人のユーザーがいれば100回個別設定が必要&lt;br/&gt;・退職時の権限削除漏れが起きやすい&lt;br/&gt;&lt;br/&gt;Roleという抽象レイヤーを置くことで：&lt;br/&gt;・権限の変更はRoleを一か所変えるだけ → 全員に反映&lt;br/&gt;・ロールを見ればできることが一目瞭然&lt;br/&gt;・再利用性が高く、保守コストが低い"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFAF1;strokeColor=#27AE60;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;"
          vertex="1" parent="1"><mxGeometry x="50" y="330" width="730" height="230" as="geometry"/></mxCell>

        <mxCell id="b4" value="&lt;b&gt;④ なぜマトリクスで権限を表現したのか&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;権限設計を図だけで表現すると「誰が何をできるか」が操作レベルで分かりにくくなります。&lt;br/&gt;&lt;br/&gt;マトリクス形式にすることで：&lt;br/&gt;・縦軸（ロール）× 横軸（操作）で網羅的に確認できる&lt;br/&gt;・「シスアドだけができること」が一目で分かる&lt;br/&gt;・「△（条件付き）」で細かいルールも表現できる&lt;br/&gt;・非エンジニアでも直感的に理解できる&lt;br/&gt;・設計レビュー・監査の場面でそのまま使える"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#F39C12;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;"
          vertex="1" parent="1"><mxGeometry x="824" y="330" width="780" height="230" as="geometry"/></mxCell>

        <mxCell id="sm" value="まとめ：「会社に依存した権限」をやめ、シンプルで理解しやすく・実装しやすく・将来拡張しやすい権限管理基盤を作ること。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;strokeColor=#2C3E50;fontColor=#FFFFFF;fontSize=15;align=center;verticalAlign=middle;fontStyle=1;"
          vertex="1" parent="1"><mxGeometry x="50" y="590" width="1554" height="60" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="⑤ユースケース" id="page5">
    <mxGraphModel dx="1422" dy="762" grid="0" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="t5" value="⑤ ユースケース　―　実際にどう動くか"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=26;fontStyle=1;fontColor=#2C3E50;"
          vertex="1" parent="1"><mxGeometry x="50" y="20" width="1554" height="50" as="geometry"/></mxCell>

        <mxCell id="u1" value="&lt;b&gt;CASE 1　新規顧客 Company の追加&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;① Companyレコードを作成（type = '顧客'）&lt;br/&gt;② 以上。権限の設定は不要。&lt;br/&gt;&lt;br/&gt;ポイント：Companyを作っても権限は自動付与されません。&lt;br/&gt;権限はUserにRoleを割り当てて初めて有効になります。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="50" y="85" width="480" height="175" as="geometry"/></mxCell>

        <mxCell id="u2" value="&lt;b&gt;CASE 2　顧客にシスアドを作成する&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;① Userレコードを作成（companyId = 顧客A社）&lt;br/&gt;② UserRoleに「シスアド」のロールを紐づける&lt;br/&gt;③ 即座にシスアドの全権限が有効になる&lt;br/&gt;&lt;br/&gt;ポイント：権限の付与はUserRoleへの1行追加だけ。&lt;br/&gt;Permissionを個別に設定する必要はありません。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="587" y="85" width="480" height="175" as="geometry"/></mxCell>

        <mxCell id="u3" value="&lt;b&gt;CASE 3　作業者をPJに直接アサイン（チームなし）&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;① User「佐藤さん」に「作業者」ロールを割り当て&lt;br/&gt;② UserProjectに（userId, projectId, teamId=null）を追加&lt;br/&gt;③ 佐藤さんはチームに属さず直接プロジェクトに参加&lt;br/&gt;&lt;br/&gt;できること：参加しているPJの更新のみ。&lt;br/&gt;他のPJは参照不可。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFAF1;strokeColor=#27AE60;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="1124" y="85" width="480" height="175" as="geometry"/></mxCell>

        <mxCell id="u4" value="&lt;b&gt;CASE 4　マネージャーがプロジェクトを管理する&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;① User「鈴木さん」に「マネージャー」ロールを割り当て&lt;br/&gt;② project:create / project:update / project:assign が可能&lt;br/&gt;③ チームを作成し、作業者をPJにアサインできる&lt;br/&gt;&lt;br/&gt;できないこと：user:create / user:delete（シスアド専用）"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#F39C12;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="50" y="295" width="480" height="185" as="geometry"/></mxCell>

        <mxCell id="u5" value="&lt;b&gt;CASE 5　ロール変更でできることが変わる&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Before：佐藤さんは「作業者」ロール&lt;br/&gt;　→ 参加PJの更新のみ可能&lt;br/&gt;&lt;br/&gt;After：佐藤さんを「マネージャー」に変更&lt;br/&gt;　① UserRoleのroleIdを更新するだけ&lt;br/&gt;　② 即座にproject:create / project:assignが可能に&lt;br/&gt;&lt;br/&gt;ポイント：コードの変更は不要。データの変更だけ。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEDEC;strokeColor=#E74C3C;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="587" y="295" width="480" height="185" as="geometry"/></mxCell>

        <mxCell id="u6" value="&lt;b&gt;CASE 6　将来的に新しい権限を追加する&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;例）新機能「レポート出力」を追加する場合&lt;br/&gt;&lt;br/&gt;① Permissionに「report:export」を1行追加&lt;br/&gt;② マネージャーのRolePermissionに紐づける&lt;br/&gt;③ マネージャーロールを持つ全員が即座に利用可能&lt;br/&gt;&lt;br/&gt;ポイント：作業者・ユーザーへの変更は一切不要。&lt;br/&gt;「ロールに追加するだけ」で拡張完了。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="1124" y="295" width="480" height="185" as="geometry"/></mxCell>

        <mxCell id="ue1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#BDC3C7;strokeWidth=2;endArrow=open;endFill=0;" edge="1" source="u1" target="u2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ue2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#BDC3C7;strokeWidth=2;endArrow=open;endFill=0;" edge="1" source="u2" target="u3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="usm" value="この設計ではデータを変えるだけで権限が変わります。コードの変更なし・デプロイなし・即時反映。これが RBAC の最大のメリットです。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;strokeColor=#2C3E50;fontColor=#FFFFFF;fontSize=14;align=center;verticalAlign=middle;fontStyle=1;"
          vertex="1" parent="1"><mxGeometry x="50" y="510" width="1554" height="55" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
