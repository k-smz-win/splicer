    <mxCell id="desc1" value="&lt;b&gt;設計の目的&lt;/b&gt;&lt;br/&gt;組織構造（誰がどのチームに属するか）と&lt;br/&gt;権限管理（誰が何をできるか）を分離する。&lt;br/&gt;人事異動や権限変更をそれぞれ独立して&lt;br/&gt;管理できる柔軟な設計。"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#AED6F1;fontSize=11;align=left;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="60" y="618" width="350" height="95" as="geometry"/>
    </mxCell>

    <mxCell id="desc2" value="&lt;b&gt;メリット&lt;/b&gt;&lt;br/&gt;・&lt;b&gt;柔軟性&lt;/b&gt;：組織変更しても権限はそのまま維持&lt;br/&gt;・&lt;b&gt;拡張性&lt;/b&gt;：新しいロールを追加するだけで対応可&lt;br/&gt;・&lt;b&gt;再利用性&lt;/b&gt;：同じロールを複数ユーザーに割当可&lt;br/&gt;・&lt;b&gt;監査容易&lt;/b&gt;：誰が何の権限を持つか一目で分かる"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFAF1;strokeColor=#A9DFBF;fontSize=11;align=left;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="430" y="618" width="380" height="95" as="geometry"/>
    </mxCell>

    <mxCell id="desc3" value="&lt;b&gt;ユースケース例&lt;/b&gt;&lt;br/&gt;・&lt;b&gt;権限変更&lt;/b&gt;：ロールを付け替えるだけでOK&lt;br/&gt;・&lt;b&gt;組織変更&lt;/b&gt;：チーム移動しても権限は維持される&lt;br/&gt;・&lt;b&gt;新入社員&lt;/b&gt;：ロール割り当てだけで即座に利用開始&lt;br/&gt;・&lt;b&gt;兼務&lt;/b&gt;：複数チーム所属・複数ロール割り当て可"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#F9E79F;fontSize=11;align=left;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="830" y="618" width="400" height="95" as="geometry"/>
    </mxCell>

