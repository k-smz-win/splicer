<mxfile host="app.diagrams.net">

  <diagram name="①RBACとは" id="page1">
    <mxGraphModel dx="1422" dy="762" grid="0" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="t1" value="① RBACとは何か"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=26;fontStyle=1;fontColor=#2C3E50;"
          vertex="1" parent="1"><mxGeometry x="50" y="20" width="1554" height="50" as="geometry"/></mxCell>

        <mxCell id="prob" value="&lt;b&gt;現状の問題（なぜ変えるのか）&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;現在の設計は「会社種別ごとに権限が決まっている」アンチパターンです。&lt;br/&gt;・会社種別（管理会社・顧客など）に権限が紐づいており、責務が曖昧&lt;br/&gt;・新しい役割を追加するたびにコードを修正しなければならない&lt;br/&gt;・誰が何の権限を持っているか一目で分からない&lt;br/&gt;&lt;br/&gt;→ これを解消するために RBAC（ロールベースアクセス制御）に整理します。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEDEC;strokeColor=#E74C3C;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="50" y="85" width="1554" height="115" as="geometry"/></mxCell>

        <mxCell id="def" value="&lt;b&gt;RBACとは（Role-Based Access Control）&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;「ユーザーに直接権限を与えるのではなく、ロール（役割）を通じて権限を管理する」考え方です。&lt;br/&gt;&lt;br/&gt;例）山田さんは「シスアド」ロールを持つ　→　シスアドは「project:create」権限を持つ　→　山田さんはproject:createができる&lt;br/&gt;&lt;br/&gt;Userの権限を変えたいときは「ロールを付け替えるだけ」。個別に権限を設定する必要はありません。"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2980B9;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="50" y="218" width="1554" height="115" as="geometry"/></mxCell>

        <mxCell id="ba" value="&lt;b&gt;RoleとPermissionの関係&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Role　＝　権限のセット（まとめ）&lt;br/&gt;Permission　＝　具体的な操作1つ&lt;br/&gt;&lt;br/&gt;例）Role「マネージャー」は以下を含む：&lt;br/&gt;　・project:create&lt;br/&gt;　・project:update&lt;br/&gt;　・project:assign&lt;br/&gt;&lt;br/&gt;RoleにPermissionをまとめておき&lt;br/&gt;UserにRoleを割り当てる"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#AED6F1;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="50" y="355" width="490" height="250" as="geometry"/></mxCell>

        <mxCell id="bb" value="&lt;b&gt;なぜUserに直接権限を持たせないのか&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;悪い例：User → Permission（直接付与）&lt;br/&gt;　・社員100人なら100回個別設定&lt;br/&gt;　・退職時に権限削除漏れが起きやすい&lt;br/&gt;　・誰が何の権限を持つか把握困難&lt;br/&gt;&lt;br/&gt;良い例：User → Role → Permission&lt;br/&gt;　・ロールを付け替えるだけで権限変更&lt;br/&gt;　・管理が一か所に集中（シンプル）&lt;br/&gt;　・「このロールは何ができるか」が明確&lt;br/&gt;　・監査しやすい"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFAF1;strokeColor=#A9DFBF;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="582" y="355" width="490" height="250" as="geometry"/></mxCell>

        <mxCell id="bc" value="&lt;b&gt;なぜ拡張しやすいのか&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;新機能の追加（例：レポート出力）：&lt;br/&gt;　1. Permission「report:export」を追加&lt;br/&gt;　2. 必要なRoleに紐づける&lt;br/&gt;　3. 完了（Userへの変更は不要）&lt;br/&gt;&lt;br/&gt;新メンバーの追加：&lt;br/&gt;　1. Userを作成&lt;br/&gt;　2. Roleを割り当てる&lt;br/&gt;　3. 完了（Permission個別設定は不要）&lt;br/&gt;&lt;br/&gt;会社や組織が変わっても&lt;br/&gt;Roleの設計は変える必要なし"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9E7;strokeColor=#F9E79F;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;"
          vertex="1" parent="1"><mxGeometry x="1114" y="355" width="490" height="250" as="geometry"/></mxCell>

        <mxCell id="fu" value="&lt;b&gt;User&lt;/b&gt;&lt;br/&gt;ユーザー"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#27AE60;strokeColor=#1E8449;fontColor=#FFFFFF;fontSize=14;arcSize=10;"
          vertex="1" parent="1"><mxGeometry x="250" y="680" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="fr" value="&lt;b&gt;Role&lt;/b&gt;&lt;br/&gt;ロール"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;strokeColor=#C0392B;fontColor=#FFFFFF;fontSize=14;arcSize=10;"
          vertex="1" parent="1"><mxGeometry x="742" y="680" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="fp" value="&lt;b&gt;Permission&lt;/b&gt;&lt;br/&gt;権限"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C0392B;strokeColor=#922B21;fontColor=#FFFFFF;fontSize=14;arcSize=10;"
          vertex="1" parent="1"><mxGeometry x="1234" y="680" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="fe1" value="ロールを持つ"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27AE60;strokeWidth=3;fontSize=12;fontStyle=1;fontColor=#1E8449;endArrow=block;endFill=1;"
          edge="1" source="fu" target="fr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fe2" value="権限を含む"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C0392B;strokeWidth=3;fontSize=12;fontStyle=1;fontColor=#C0392B;endArrow=block;endFill=1;"
          edge="1" source="fr" target="fp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fl" value="この間接的な紐づけが RBAC の本質"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=2;fontColor=#7F8C8D;"
          vertex="1" parent="1"><mxGeometry x="250" y="768" width="1154" height="25" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

