        <mxCell id="r1c3" value="○" style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=22;align=center;fontColor=#27AE60;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="535" y="195" width="155" height="60" as="geometry"/></mxCell>
